# Copy this file to `.env` and fill in the values from your Entra ID app registration.
# Do NOT commit the real `.env` file (it is git-ignored).

# Directory (tenant) ID of your Entra ID tenant
AZURE_TENANT_ID=

# Application (client) ID of the service principal / app registration
AZURE_CLIENT_ID=

# Client secret value created under "Certificates & secrets"
AZURE_CLIENT_SECRET=

# ID of the target Fabric workspace the service principal has access to
FABRIC_WORKSPACE_ID=
