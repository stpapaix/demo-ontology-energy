{
  "name": "EnergyOntology",
  "displayName": "energy_ontology",
  "description": "Fabric IQ ontology for the Schneider Electric energy domain, bound to the silver lakehouse conformed model. Entity types and relationships are backed by silver Delta tables via the lakehouse SQL endpoint (dbo). This file is the deploy source consumed by src/deploy_ontology.py.",
  "sourceLakehouse": "lh_silver",
  "sourceSchema": "dbo",
  "entities": [
    {
      "name": "Region",
      "table": "dim_region",
      "key": "region_id",
      "displayNameProperty": "region_name",
      "properties": [
        { "name": "region_id", "valueType": "String" },
        { "name": "region_code", "valueType": "String" },
        { "name": "region_name", "valueType": "String" }
      ]
    },
    {
      "name": "Site",
      "table": "dim_site",
      "key": "site_id",
      "displayNameProperty": "site_name",
      "properties": [
        { "name": "site_id", "valueType": "String" },
        { "name": "site_name", "valueType": "String" },
        { "name": "country", "valueType": "String" },
        { "name": "region_id", "valueType": "String" },
        { "name": "site_type", "valueType": "String" },
        { "name": "contracted_power_kw", "valueType": "Double" }
      ]
    },
    {
      "name": "Device",
      "table": "dim_device",
      "key": "device_id",
      "displayNameProperty": "device_id",
      "properties": [
        { "name": "device_id", "valueType": "String" },
        { "name": "site_id", "valueType": "String" },
        { "name": "device_type", "valueType": "String" },
        { "name": "model", "valueType": "String" },
        { "name": "measurement_unit", "valueType": "String" },
        { "name": "is_active", "valueType": "Boolean" }
      ]
    },
    {
      "name": "EnergyReading",
      "table": "fact_energy_consumption",
      "key": "reading_id",
      "displayNameProperty": "reading_id",
      "properties": [
        { "name": "reading_id", "valueType": "String" },
        { "name": "device_id", "valueType": "String" },
        { "name": "site_id", "valueType": "String" },
        { "name": "timestamp", "valueType": "DateTime" },
        { "name": "energy_kwh", "valueType": "Double" },
        { "name": "active_power_kw", "valueType": "Double" },
        { "name": "power_factor", "valueType": "Double" }
      ]
    },
    {
      "name": "BillingRecord",
      "table": "fact_energy_cost",
      "key": "cost_id",
      "displayNameProperty": "cost_id",
      "properties": [
        { "name": "cost_id", "valueType": "String" },
        { "name": "site_id", "valueType": "String" },
        { "name": "billing_period", "valueType": "String" },
        { "name": "energy_cost", "valueType": "Double" },
        { "name": "co2_emissions_kg", "valueType": "Double" },
        { "name": "currency", "valueType": "String" }
      ]
    }
  ],
  "relationships": [
    { "name": "locatedIn", "source": "Site", "target": "Region", "table": "dim_site", "sourceKeyColumn": "site_id", "targetKeyColumn": "region_id" },
    { "name": "hasDevice", "source": "Site", "target": "Device", "table": "dim_device", "sourceKeyColumn": "site_id", "targetKeyColumn": "device_id" },
    { "name": "produces", "source": "Device", "target": "EnergyReading", "table": "fact_energy_consumption", "sourceKeyColumn": "device_id", "targetKeyColumn": "reading_id" },
    { "name": "billedFor", "source": "Site", "target": "BillingRecord", "table": "fact_energy_cost", "sourceKeyColumn": "site_id", "targetKeyColumn": "cost_id" }
  ]
}
